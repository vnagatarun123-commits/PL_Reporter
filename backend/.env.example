# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/pl_reporter?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this"
JWT_EXPIRES_IN="7d"

# Server
PORT=4000
NODE_ENV=development

# OTP (use a real SMS provider in production — e.g. Twilio, MSG91)
OTP_EXPIRY_MINUTES=10
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# AWS S3 / Cloudflare R2 (for video/image uploads)
# S3_BUCKET_NAME=
# S3_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_ENDPOINT=   # only needed for R2

# Upload limits
MAX_VIDEO_SIZE_MB=500
MAX_IMAGE_SIZE_MB=10
