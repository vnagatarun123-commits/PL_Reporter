generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Reporter (app user) ───────────────────────────────────────────────────

model Reporter {
  id                 String    @id @default(uuid())
  mobile             String    @unique
  fullName           String    @default("")
  email              String?
  address            String    @default("")
  reporterLicence    String    @default("")
  yearsOfExperience  String    @default("")
  artStyle           String    @default("")
  bio                String    @default("")
  avatarUrl          String?
  followers          Int       @default(0)
  following          Int       @default(0)
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  videos             Video[]
  otps               Otp[]

  @@map("reporters")
}

// ─── OTP ──────────────────────────────────────────────────────────────────

model Otp {
  id         String    @id @default(uuid())
  mobile     String
  code       String
  expiresAt  DateTime
  used       Boolean   @default(false)
  createdAt  DateTime  @default(now())

  reporter   Reporter? @relation(fields: [reporterId], references: [id])
  reporterId String?

  @@index([mobile])
  @@map("otps")
}

// ─── Video Content ────────────────────────────────────────────────────────

enum VideoStatus {
  DRAFT
  IN_REVIEW
  PUBLISHED
  REJECTED
  REPORTED
}

enum VideoType {
  VIDEO
  SHORTS
}

model Video {
  id            String       @id @default(uuid())
  title         String
  description   String       @default("")
  type          VideoType    @default(VIDEO)
  status        VideoStatus  @default(DRAFT)
  videoUrl      String?
  thumbnailUrl  String?
  duration      Int?         // seconds
  views         Int          @default(0)
  likes         Int          @default(0)
  rejectionNote String?      // filled by admin when rejected
  reportReason  String?      // filled when reported

  reporter      Reporter     @relation(fields: [reporterId], references: [id])
  reporterId    String

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([reporterId])
  @@index([status])
  @@map("videos")
}
